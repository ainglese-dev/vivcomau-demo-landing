# Vite client env vars — inlined into the production bundle at build time.
# PUBLIC by design. Never put secrets (API keys, tokens) here.
# Set real values in Cloudflare Pages project settings → Environment variables.

# Google Ads account ID. Format: AW-XXXXXXXXXX. Leave unset to disable gtag.
VITE_GOOGLE_ADS_ID=

# Conversion label for the contact-form conversion action, from the Google Ads UI.
VITE_CONVERSION_LABEL_FORM=

# Cloudflare Turnstile site key. Public — safe to commit.
# Create a widget at dash.cloudflare.com → Turnstile → Add site.
# Leave unset to use the Cloudflare test key (always passes) during local dev.
VITE_TURNSTILE_SITE_KEY=
